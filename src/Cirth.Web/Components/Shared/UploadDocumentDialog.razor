@inject IMediator Mediator
@inject ISnackbar Snackbar
@using TagDto = Cirth.Application.Features.Tags.CreateTag.TagDto

<MudDialog Style="min-width:560px">
    <TitleContent>
        <MudText Typo="Typo.h6">Novo documento</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">

            <MudTextField @bind-Value="_title" Label="Título" Required="true"
                          RequiredError="Título é obrigatório" Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudToggleGroup T="string" @bind-Value="_mode" SelectionMode="SelectionMode.SingleSelection"
                            Class="mb-3">
                <MudToggleItem Value="@("file")">Arquivo</MudToggleItem>
                <MudToggleItem Value="@("url")">URL</MudToggleItem>
            </MudToggleGroup>

            @if (_mode == "file")
            {
                <MudFileUpload T="IBrowserFile" @bind-Files="_file" Accept=".pdf,.docx,.md,.txt,.html"
                               Class="mb-3">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AttachFile">
                            Selecionar arquivo
                        </MudButton>
                    </ActivatorContent>
                    <SelectedTemplate>
                        @if (context is not null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-1 ml-1">
                                @context.Name (@FormatSize(context.Size))
                            </MudText>
                        }
                    </SelectedTemplate>
                </MudFileUpload>
            }
            else
            {
                <MudTextField @bind-Value="_url" Label="URL" Placeholder="https://..." Class="mb-3"
                              Variant="Variant.Outlined"
                              Validation="@((Func<string, string?>)ValidateUrl)" />
            }

            <MudTextField @bind-Value="_author" Label="Autor (opcional)" Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudDivider Class="mb-3" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Tags</MudText>

            @if (_loadingTags)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-2" />
            }
            else if (_tags.Count > 0)
            {
                <div class="d-flex flex-wrap gap-1 mb-3">
                    @foreach (var tag in _tags)
                    {
                        var selected = _selectedTagIds.Contains(tag.Id);
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                 Style="@GetTagStyle(tag, selected)"
                                 OnClick="@(() => ToggleTag(tag.Id))"
                                 Icon="@(selected ? Icons.Material.Filled.Check : "")">
                            @tag.Name
                        </MudChip>
                    }
                </div>
            }

            <div class="d-flex align-center gap-2">
                <MudTextField @bind-Value="_newTagName" Label="Nova tag" Variant="Variant.Outlined"
                              Margin="Margin.Dense" MaxLength="100" Style="flex:1" />
                <MudTextField @bind-Value="_newTagColor" Label="Cor" Variant="Variant.Outlined"
                              Margin="Margin.Dense" MaxLength="7" Placeholder="#RRGGBB"
                              Style="width:100px" />
                <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                               Color="Color.Primary" Size="Size.Medium"
                               Disabled="@(string.IsNullOrWhiteSpace(_newTagName) || _creatingTag)"
                               OnClick="CreateNewTag"
                               title="Criar tag" />
            </div>

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel" Disabled="@_uploading">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@Upload"
                   Disabled="@_uploading">
            @if (_uploading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Enviar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _uploading;
    private string _title = string.Empty;
    private string _mode = "file";
    private string _url = string.Empty;
    private string _author = string.Empty;
    private IBrowserFile? _file;

    // Tags
    private bool _loadingTags = true;
    private bool _creatingTag;
    private List<TagDto> _tags = [];
    private HashSet<Guid> _selectedTagIds = [];
    private string _newTagName = string.Empty;
    private string _newTagColor = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Mediator.Send(new ListTagsQuery());
            if (result.IsSuccess)
                _tags = result.Value!.ToList();
        }
        catch
        {
            // Tags failed to load — user can still create inline
        }
        finally
        {
            _loadingTags = false;
        }
    }

    private void ToggleTag(Guid id)
    {
        if (!_selectedTagIds.Remove(id))
            _selectedTagIds.Add(id);
    }

    private async Task CreateNewTag()
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) return;
        _creatingTag = true;
        try
        {
            var color = IsValidHex(_newTagColor) ? _newTagColor : null;
            var result = await Mediator.Send(new CreateTagCommand(_newTagName.Trim(), color));
            if (result.IsSuccess)
            {
                var dto = result.Value!;
                _tags.Add(dto);
                _tags = [.. _tags.OrderBy(t => t.Name)];
                _selectedTagIds.Add(dto.Id);
                _newTagName = string.Empty;
                _newTagColor = string.Empty;
                Snackbar.Add($"Tag \"{dto.Name}\" criada.", Severity.Success);
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao criar tag: {ex.Message}", Severity.Error);
        }
        finally
        {
            _creatingTag = false;
        }
    }

    private static string GetTagStyle(TagDto tag, bool selected)
    {
        if (tag.Color is null) return string.Empty;
        return selected
            ? $"background-color:{tag.Color};color:#fff;border-color:{tag.Color}"
            : $"color:{tag.Color};border-color:{tag.Color}";
    }

    private static bool IsValidHex(string? color) =>
        !string.IsNullOrWhiteSpace(color) &&
        System.Text.RegularExpressions.Regex.IsMatch(color, "^#[0-9A-Fa-f]{6}$");

    private string? ValidateUrl(string url) =>
        Uri.IsWellFormedUriString(url, UriKind.Absolute) ? null : "URL inválida";

    private void Cancel() => MudDialog.Cancel();

    private async Task Upload()
    {
        await _form.Validate();
        if (!_isValid)
        {
            Snackbar.Add("Preencha os campos obrigatórios.", Severity.Warning);
            return;
        }

        _uploading = true;
        try
        {
            Result<UploadDocumentResult> result;

            if (_mode == "url")
            {
                if (!Uri.IsWellFormedUriString(_url, UriKind.Absolute))
                {
                    Snackbar.Add("URL inválida.", Severity.Warning);
                    return;
                }

                result = await Mediator.Send(new UploadDocumentCommand(
                    _title, "url.txt", Stream.Null, "text/plain", 0,
                    _author.NullIfEmpty(), true, _url));
            }
            else
            {
                if (_file is null)
                {
                    Snackbar.Add("Selecione um arquivo.", Severity.Warning);
                    return;
                }

                var mimeType = ResolveMimeType(_file);
                const long MaxSize = 50 * 1024 * 1024;
                await using var stream = _file.OpenReadStream(MaxSize);
                result = await Mediator.Send(new UploadDocumentCommand(
                    _title, _file.Name, stream, mimeType, _file.Size,
                    _author.NullIfEmpty(), false, null));
            }

            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
                return;
            }

            var docId = result.Value!.DocumentId;
            foreach (var tagId in _selectedTagIds)
            {
                try { await Mediator.Send(new AddTagToDocumentCommand(docId, tagId)); }
                catch { /* tag assignment failure should not block upload success */ }
            }

            Snackbar.Add("Documento enviado e em processamento!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao enviar documento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private static string ResolveMimeType(IBrowserFile file)
    {
        var ct = file.ContentType;
        if (!string.IsNullOrWhiteSpace(ct) && ct != "application/octet-stream")
            return ct;

        return Path.GetExtension(file.Name).ToLowerInvariant() switch
        {
            ".pdf"  => "application/pdf",
            ".docx" => "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            ".md" or ".markdown" => "text/markdown",
            ".html" or ".htm"    => "text/html",
            _       => "text/plain"
        };
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}
