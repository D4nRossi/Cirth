@if (Status == "Indexed")
{
    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Indexado</MudChip>
}
else if (Status == "Processing")
{
    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.HourglassTop">Processando</MudChip>
}
else if (Status == "Failed")
{
    <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Error">Falhou</MudChip>
}
else
{
    <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Pending">Pendente</MudChip>
}

@code {
    [Parameter] public string Status { get; set; } = string.Empty;
}
