@page "/admin"
@attribute [Authorize(Policy = "Admin")]
@inject IMediator Mediator
@inject ISnackbar Snackbar

@using Cirth.Application.Features.Identity.GetMyProfile

<PageTitle>Administração — Cirth</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-family:'Cinzel',serif">Administração</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="my-4" />
}
else if (_profile is not null)
{
    <MudGrid>

        {{!-- Perfil --}}
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height:100%">
                <div class="d-flex align-center gap-3 mb-4">
                    <MudAvatar Size="Size.Large" Color="Color.Primary"
                               Style="font-family:'Cinzel',serif;font-size:1.4rem">
                        @_profile.DisplayName[0]
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6">@_profile.DisplayName</MudText>
                        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">@_profile.Email</MudText>
                    </div>
                </div>
                <MudDivider Class="mb-3" />
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2">Papel</MudText>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_profile.Role == "Admin" ? Color.Warning : Color.Default)">
                        @_profile.Role
                    </MudChip>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Membro desde</MudText>
                    <MudText Typo="Typo.body2">@_profile.MemberSince.ToString("dd/MM/yyyy")</MudText>
                </div>
            </MudPaper>
        </MudItem>

        {{!-- Estatísticas --}}
        <MudItem xs="12" md="8">
            <MudGrid>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h4" Class="mt-1">@_profile.DocumentCount</MudText>
                        <MudText Typo="Typo.caption">Documentos</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h4" Class="mt-1">@_profile.CollectionCount</MudText>
                        <MudText Typo="Typo.caption">Coleções</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1">
                        <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Tertiary" Size="Size.Large" />
                        <MudText Typo="Typo.h4" Class="mt-1">@_profile.TagCount</MudText>
                        <MudText Typo="Typo.caption">Tags</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-4 text-center" Elevation="1">
                        <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h4" Class="mt-1">@_profile.ConversationCount</MudText>
                        <MudText Typo="Typo.caption">Conversas</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudItem>

        {{!-- Quotas --}}
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-4">Quotas (hoje)</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.body2" Class="mb-1">
                            Tokens — @_profile.TokensUsedToday.ToString("N0") / @_profile.DailyTokenLimit.ToString("N0")
                        </MudText>
                        <MudProgressLinear Value="@TokenPct" Color="@TokenColor" Rounded="true" Size="Size.Medium" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.body2" Class="mb-1">
                            Uploads — @_profile.UploadsToday / @_profile.DailyUploadLimit
                        </MudText>
                        <MudProgressLinear Value="@UploadPct" Color="@UploadColor" Rounded="true" Size="Size.Medium" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.body2" Class="mb-1">
                            Armazenamento — @FormatBytes(_profile.StorageUsedBytes) / @FormatBytes(_profile.StorageLimitBytes)
                        </MudText>
                        <MudProgressLinear Value="@StoragePct" Color="@StorageColor" Rounded="true" Size="Size.Medium" />
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

    </MudGrid>
}

@code {
    private bool _loading = true;
    private MyProfileDto? _profile;

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new GetMyProfileQuery());
        if (result.IsSuccess)
            _profile = result.Value;
        else
            Snackbar.Add(result.Error!.Message, Severity.Error);
        _loading = false;
    }

    private double TokenPct => _profile is null || _profile.DailyTokenLimit == 0
        ? 0 : Math.Min(100.0, _profile.TokensUsedToday * 100.0 / _profile.DailyTokenLimit);

    private double UploadPct => _profile is null || _profile.DailyUploadLimit == 0
        ? 0 : Math.Min(100.0, _profile.UploadsToday * 100.0 / _profile.DailyUploadLimit);

    private double StoragePct => _profile is null || _profile.StorageLimitBytes == 0
        ? 0 : Math.Min(100.0, _profile.StorageUsedBytes * 100.0 / _profile.StorageLimitBytes);

    private Color TokenColor => TokenPct >= 90 ? Color.Error : TokenPct >= 70 ? Color.Warning : Color.Success;
    private Color UploadColor => UploadPct >= 90 ? Color.Error : UploadPct >= 70 ? Color.Warning : Color.Success;
    private Color StorageColor => StoragePct >= 90 ? Color.Error : StoragePct >= 70 ? Color.Warning : Color.Success;

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1L * 1024 * 1024 * 1024 => $"{bytes / (1024.0 * 1024 * 1024):F1} GB",
        >= 1L * 1024 * 1024        => $"{bytes / (1024.0 * 1024):F1} MB",
        >= 1024L                   => $"{bytes / 1024.0:F1} KB",
        _                          => $"{bytes} B"
    };
}
