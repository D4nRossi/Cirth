@page "/search"
@attribute [Authorize]
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Busca — Cirth</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-family:'Cinzel',serif">Busca Híbrida</MudText>

<MudGrid>
    <MudItem xs="12" md="10">
        <MudTextField @bind-Value="_query" Label="Pesquisar" Variant="Variant.Outlined"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                      OnAdornmentClick="ExecuteSearch" OnKeyDown="@OnKeyDown"
                      FullWidth="true" />
    </MudItem>
    <MudItem xs="12" md="2" Class="d-flex align-center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="ExecuteSearch" Disabled="_loading">Buscar</MudButton>
    </MudItem>
</MudGrid>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="my-4" />
}
else if (_result is not null)
{
    <div class="mt-2 mb-4">
        <MudText Typo="Typo.caption" Class="cirth-muted">
            @_result.Hits.Count resultado(s) em @_result.Elapsed.TotalMilliseconds.ToString("F0")ms
        </MudText>
    </div>

    @if (_result.Hits.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Nenhum resultado encontrado para "@_result.Query".</MudAlert>
    }
    else
    {
        @foreach (var hit in _result.Hits)
        {
            <MudCard Class="mb-3 cirth-search-hit" @onclick="@(() => Nav.NavigateTo($"/documents/{hit.DocumentId}"))">
                <MudCardContent>
                    <div class="d-flex align-center justify-space-between mb-1">
                        <MudLink Href="@($"/documents/{hit.DocumentId}")" Class="cirth-link">
                            <MudText Typo="Typo.subtitle1">@hit.DocumentTitle</MudText>
                        </MudLink>
                        <MudText Typo="Typo.caption" Class="cirth-muted">Score: @hit.Score.ToString("F3")</MudText>
                    </div>
                    @if (!string.IsNullOrEmpty(hit.Highlight))
                    {
                        <MudText Typo="Typo.body2" Class="cirth-highlight">@((MarkupString)hit.Highlight)</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="cirth-snippet">@hit.Content[..Math.Min(200, hit.Content.Length)]...</MudText>
                    }
                    <div class="mt-2">
                        @foreach (var tag in hit.Tags.Take(4))
                        {
                            <MudChip T="string" Size="Size.Small" Class="mr-1">@tag</MudChip>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        }
    }
}

@code {
    [SupplyParameterFromQuery] public string? Q { get; set; }

    private string _query = string.Empty;
    private bool _loading = false;
    private HybridSearchResult? _result;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Q))
        {
            _query = Q;
            await ExecuteSearch();
        }
    }

    private async Task ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        _loading = true;
        try
        {
            var result = await Mediator.Send(new HybridSearchQuery(_query));
            if (result.IsSuccess)
                _result = result.Value;
            else
                _result = null;
        }
        catch
        {
            _result = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ExecuteSearch();
    }
}
