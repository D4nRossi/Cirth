@page "/documents/{Id:guid}"
@attribute [Authorize]
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

@using Cirth.Application.Features.Documents.GetDocument

<PageTitle>@(_doc?.Title ?? "Documento") — Cirth</PageTitle>

<div class="d-flex align-center gap-3 mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/documents"))"
                   title="Voltar" />
    <MudText Typo="Typo.h4" Style="font-family:'Cinzel',serif">
        @(_doc?.Title ?? "Carregando...")
    </MudText>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="my-4" />
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
}
else if (_doc is not null)
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudChip T="string" Size="Size.Small">@_doc.SourceType</MudChip>
                    <DocumentStatusChip Status="@_doc.Status" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_doc.Author))
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <b>Autor:</b> @_doc.Author
                    </MudText>
                }

                <MudText Typo="Typo.body2" Class="mb-1">
                    <b>Criado em:</b> @_doc.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3">
                    <b>Atualizado em:</b> @_doc.UpdatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                </MudText>

                @if (_doc.Tags.Count > 0)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Tags</MudText>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var tag in _doc.Tags)
                        {
                            <MudChip T="string" Size="Size.Small"
                                     Style="@(tag.Color is not null ? $"background-color:{tag.Color};color:#fff" : "")">
                                @tag.Name
                            </MudChip>
                        }
                    </div>
                }

                @if (_doc.Collections.Count > 0)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Coleções</MudText>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var col in _doc.Collections)
                        {
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Folder">
                                @col.Name
                            </MudChip>
                        }
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Versões</MudText>
                @foreach (var v in _doc.Versions)
                {
                    <div class="d-flex align-center justify-space-between mb-2">
                        <div>
                            <MudText Typo="Typo.body2">
                                v@(v.VersionNumber) @(v.IsCurrent ? "(atual)" : "")
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
                                @FormatSize(v.SizeBytes) · @v.CreatedAt.LocalDateTime.ToString("dd/MM/yy HH:mm")
                            </MudText>
                        </div>
                        @if (v.IsCurrent)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        }
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private string? _error;
    private DocumentDetailDto? _doc;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new GetDocumentQuery(Id));
            if (result.IsSuccess)
                _doc = result.Value;
            else
                _error = result.Error!.Message;
        }
        catch (Exception ex)
        {
            _error = $"Erro ao carregar documento: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}
