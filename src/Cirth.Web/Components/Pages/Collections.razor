@page "/collections"
@attribute [Authorize]
@inject IMediator Mediator
@inject ISnackbar Snackbar

<PageTitle>Coleções — Cirth</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-family:'Cinzel',serif">Coleções</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" Class="d-flex justify-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CreateNewFolder"
                   OnClick="@(() => _createOpen = true)">
            Nova coleção
        </MudButton>
    </MudItem>
</MudGrid>

@if (_createOpen)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3">Nova coleção</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_newName" Label="Nome" Variant="Variant.Outlined"
                              MaxLength="200" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_newDesc" Label="Descrição (opcional)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" Class="d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateCollection"
                           Disabled="@(_saving || string.IsNullOrWhiteSpace(_newName))">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Criar
                </MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => { _createOpen = false; _newName = string.Empty; _newDesc = string.Empty; })">
                    Cancelar
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="my-4" />
}
else if (_collections.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        Nenhuma coleção criada ainda. Organize seus documentos criando uma coleção.
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var col in _collections)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Class="cirth-card">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@col.Name</MudText>
                        @if (!string.IsNullOrWhiteSpace(col.Description))
                        {
                            <MudText Typo="Typo.body2" Class="mt-1" Style="color:var(--mud-palette-text-secondary)">
                                @col.Description
                            </MudText>
                        }
                        <MudText Typo="Typo.caption" Class="mt-2">
                            @col.DocumentCount documento(s) · criada @col.CreatedAt.LocalDateTime.ToString("dd/MM/yy")
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private bool _createOpen;
    private bool _saving;
    private string _newName = string.Empty;
    private string _newDesc = string.Empty;
    private List<CollectionSummaryDto> _collections = [];

    protected override async Task OnInitializedAsync() => await LoadCollections();

    private async Task LoadCollections()
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new ListCollectionsQuery());
            if (result.IsSuccess)
                _collections = result.Value!.ToList();
            else
                Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar coleções: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateCollection()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        _saving = true;
        try
        {
            var result = await Mediator.Send(new CreateCollectionCommand(_newName.Trim(), _newDesc.Trim().NullIfEmpty()));
            if (result.IsSuccess)
            {
                Snackbar.Add("Coleção criada!", Severity.Success);
                _createOpen = false;
                _newName = string.Empty;
                _newDesc = string.Empty;
                await LoadCollections();
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao criar coleção: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
