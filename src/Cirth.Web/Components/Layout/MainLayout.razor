@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudThemeProvider Theme="@CirthTheme.Build()" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Transparent" Class="cirth-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="cirth-logo">Cirth</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchQuery" Placeholder="Buscar no acervo..."
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="cirth-search" Style="max-width:400px"
                      OnKeyUp="@OnSearchKeyUp" />
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" AnchorOrigin="Origin.BottomRight">
            <MudMenuItem Href="/apikeys">API Keys</MudMenuItem>
            <MudMenuItem OnClick="@SignOut">Sair</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Persistent"
               ClipMode="DrawerClipMode.Always" Width="260px">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Início</MudNavLink>
            <MudNavLink Href="/documents" Icon="@Icons.Material.Filled.LibraryBooks">Documentos</MudNavLink>
            <MudNavLink Href="/chat" Icon="@Icons.Material.Filled.Chat">Chat RAG</MudNavLink>
            <MudNavLink Href="/search" Icon="@Icons.Material.Filled.Search">Busca</MudNavLink>
            <MudNavLink Href="/saved" Icon="@Icons.Material.Filled.Bookmark">Respostas salvas</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/collections" Icon="@Icons.Material.Filled.Folder">Coleções</MudNavLink>
            <MudNavLink Href="/tags" Icon="@Icons.Material.Filled.Label">Tags</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.Shield">Administração</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="cirth-main">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _searchQuery = string.Empty;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
    }

    private void SignOut() => Nav.NavigateTo("/signout", forceLoad: true);
}
