@using Cirth.Web.Components.Layout
@using Microsoft.AspNetCore.Components.Authorization

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <LayoutView Layout="typeof(MainLayout)">
                    <MudContainer Class="d-flex flex-column align-center justify-center" Style="min-height:60vh">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:5rem;opacity:.3" Class="mb-4" />
                        <MudText Typo="Typo.h5" Class="mb-2">Acesso negado</MudText>
                        <MudText Typo="Typo.body1" Class="mb-6" Style="color:var(--mud-palette-text-secondary)">
                            Você não tem permissão para acessar essa página.
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
                                   StartIcon="@Icons.Material.Filled.Home">
                            Voltar ao início
                        </MudButton>
                    </MudContainer>
                </LayoutView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Página não encontrada — Cirth</PageTitle>
        <LayoutView Layout="typeof(MainLayout)">
            <MudContainer Class="d-flex flex-column align-center justify-center" Style="min-height:60vh">
                <MudText Typo="Typo.h1" Style="font-family:'Cinzel',serif;font-size:6rem;opacity:.3">404</MudText>
                <MudText Typo="Typo.h5" Class="mb-2">Essa página não existe nos arquivos.</MudText>
                <MudText Typo="Typo.body1" Class="mb-6" Style="color:var(--mud-palette-text-secondary)">
                    O caminho que você acessou não corresponde a nenhuma rota do Cirth.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    Voltar ao início
                </MudButton>
            </MudContainer>
        </LayoutView>
    </NotFound>
</Router>
