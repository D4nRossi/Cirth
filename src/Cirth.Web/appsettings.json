{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.SignalR": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/cirth-web-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj} {Exception}{NewLine}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=cirth;Username=cirth;Password=cirth_dev_pass",
    "Redis": "localhost:6379"
  },
  "Qdrant": {
    "Endpoint": "http://localhost:6334",
    "ApiKey": "",
    "HealthEndpoint": "http://localhost:6333/healthz"
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin123",
    "UseSsl": false,
    "UploadsBucket": "cirth-uploads",
    "ExportsBucket": "cirth-exports"
  },
  "AzureAi": {
    "Chat": {
      "Endpoint": "https://danie-mc4ryviy-westeurope.openai.azure.com/openai/v1",
      "ApiKey": "",
      "Deployment": "gpt-4.1",
      "MiniDeployment": "gpt-4.1-mini"
    },
    "Embedding": {
      "Endpoint": "https://danie-mc4ryviy-westeurope.cognitiveservices.azure.com/",
      "ApiKey": "",
      "Deployment": "text-embedding-ada-002",
      "Dimensions": 1536
    }
  },
  "EntraId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "c050c98c-b463-4591-ac3b-deb782c0ba6e",
    "ClientId": "",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Rag": {
    "ChunkSize": 800,
    "ChunkOverlap": 100,
    "RetrievalTopK": 8,
    "RrfK": 60,
    "SavedAnswerThreshold": 0.85
  },
  "Quotas": {
    "DefaultDailyTokenLimit": 100000,
    "DefaultDailyUploadLimit": 50,
    "DefaultStorageLimitBytes": 5368709120
  },
  "Worker": {
    "JobPollingIntervalSeconds": 5,
    "MaxConcurrentJobs": 3
  },
  "AllowedHosts": "*"
}
