# ============================================================
# Cirth — Environment Configuration Example
# Copy to .env and fill with real values. NEVER commit .env.
# Set file permission: chmod 600 .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=cirth
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_CONN=Host=postgres;Port=5432;Database=cirth;Username=cirth;Password=change-me-strong-password

# --- Redis ---
REDIS_PASSWORD=change-me-redis-password
REDIS_CONN=redis:6379,password=change-me-redis-password

# --- Qdrant ---
QDRANT_API_KEY=change-me-qdrant-api-key

# --- MinIO ---
MINIO_ROOT_USER=cirth-minio-admin
MINIO_ROOT_PASSWORD=change-me-minio-password

# --- Azure AI Foundry ---
AZURE_AI_ENDPOINT=https://danie-mer384sb-eastus2.services.ai.azure.com/
AZURE_AI_API_KEY=your-azure-ai-key

# --- Entra ID OIDC ---
ENTRA_TENANT_ID=c050c98c-b463-4591-ac3b-deb782c0ba6e
ENTRA_CLIENT_ID=your-app-registration-client-id
ENTRA_CLIENT_SECRET=your-app-registration-client-secret

# --- Backup (rclone para Backblaze B2) ---
B2_KEY_ID=your-b2-application-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET=cirth-backups

# --- App settings ---
CIRTH_PUBLIC_URL=https://cirth.local
CIRTH_DEFAULT_TOKEN_LIMIT_PER_DAY=100000
CIRTH_DEFAULT_UPLOAD_LIMIT_PER_DAY=50
CIRTH_DEFAULT_STORAGE_LIMIT_GB=5
